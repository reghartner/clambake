node_modules/
*.log
.DS_Store

# atomic-write temp files (write to <file>.tmp-<pid>-<n> then rename)
*.tmp-*

# live board data — keep the repo generic; ship only the demo project
/data/projects/*
!/data/projects/.gitkeep
!/data/projects/demo/

# personal / project-specific watcher scripts + their state (generic watch.js is tracked)
/board_watch_*.js
/.board_watch_*

# uploaded attachment binaries (incl. the demo's) — don't track screenshots
data/projects/*/attachments/

# watcher state snapshots + liveness markers
data/projects/*/.watch_state.json
data/projects/*/.watch_live.json

# append-only event log (runtime stream; not source-of-truth)
data/projects/*/events.ndjson

# watch subscriptions registry + per-actor inboxes (runtime state)
data/projects/*/watchers.json
data/projects/*/inbox/
